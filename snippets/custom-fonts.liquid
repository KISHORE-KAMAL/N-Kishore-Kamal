{%- style -%}
   @font-face {
      font-family: "jost";
      font-style: normal;
      font-weight: 300;
      font-display: swap;
      src: url("{{'Jost-Light.ttf' | asset_url }}");
  }
   @font-face {
      font-family: "jost";
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url("{{'Jost-Regular.ttf' | asset_url }}");
  }
  @font-face {
      font-family: "jost";
      font-style: normal;
      font-weight: 500;
      font-display: swap;
      src: url("{{'Jost-Medium.ttf' | asset_url }}");
  }
   @font-face {
      font-family: "Lustria";
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url("{{'Lustria-Regular.ttf' | asset_url }}");
  }
{%- endstyle -%}
