{{ 'custom-header.css' | asset_url | stylesheet_tag }}

<script src="{{ 'custom-header.js' | asset_url }}" defer></script>

<style>
  .section-padding-{{section.id }} {
     padding-top: {{ section.settings.padding_top_mobile}}px;
     padding-bottom: {{ section.settings.padding_bottom_mobile}}px;
   }
   @media screen and (min-width:750px){
     .section-padding-{{section.id }} {
       padding-top: {{ section.settings.padding_top_desktop }}px;
       padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
     }
   }
</style>
<div class="custom-header custom-header__main-container">
  <div class="cusom-header__wrapper">
    {% capture button %}
        {% if section.settings.navigation_url %}
            <a href="{{ section.settings.navigation_url }}">
              <button
                class="custom-header-button"
                type="button"
              >
                <span class="transition-effect"> </span>
                <span class="button-text">
                  {{ section.settings.button_text }}
                </span>
                <span class="custom-header__right-icon-container">
                  {%- render 'ecomexperts-icons', icon_name: 'icon-arrow' -%}
                </span>
              </button>
            </a>
          {% else %}
            <button
              class="custom-header-button"
              type="button"
              disabled
            >
              <span class="transition-effect"> </span>
              <span class="button-text">
                {{ section.settings.button_text }}
              </span>
              <span class="custom-header__right-icon-container">
                {%- render 'ecomexperts-icons', icon_name: 'icon-arrow' -%}
              </span>
            </button>
          {% endif %}
    {% endcapture %}
    <header class="custom-header__container page-width section-padding-{{section.id }} color-{{ section.settings.color_scheme }}">
      <div class="custom-header__menu large-up-hide">
        <div class="menu-icons-container">
          <span class="custom-header__menu-icon-container">
            {%- render 'ecomexperts-icons', icon_name: 'icon-menu' -%}
          </span>
          <span class="custom-header__cross-icon-container hidden">
            {%- render 'ecomexperts-icons', icon_name: 'icon-cross' -%}
          </span>
        </div>
      </div>
      {% if section.settings.image != blank or section.settings.heading != blank %}
        <div class="custom-header__logo-container">
          <h1 class="custom-header-logo">
            <a href="{{ shop.url }}">
              {% if section.settings.image != blank %}
                <img src="{{ section.settings.image | image_url }}" height="auto" width="auto">
              {% elsif section.settings.heading != blank %}
                <span class="h2">{{ section.settings.heading }}</span>
              {% endif %}
            </a>
          </h1>
        </div>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="custom-header__description-conatiner small-hide medium-hide">
          <p class="custom-header__description">
            {{ section.settings.description }}
          </p>
        </div>
      {% endif %}
      {% if button %}
        <div class="custom-header__button-conatiner small-hide medium-hide">
          {{ button }}
        </div>
      {% endif %}
    </header>
    <div class="custom-header__drawer-container color-{{ section.settings.drawer_color_scheme }} large-up-hide">
      <div class="header-drawer-warpper">
        {% if section.settings.description != blank %}
          <div class="custom-header__drawer-description">
            <p class="custom-header__description">
              {{ section.settings.description }}
            </p>
          </div>
        {% endif %}
        {% if button %}
          <div class="custom-header__drawer-button">
            {{ button }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "t:sections.custom-header.name",
  "class": "custom-header-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.custom-header.settings.content_customization"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "drawer_color_scheme",
      "label": "t:sections.custom-header.settings.drawer_color_scheme",
      "default": "scheme-2"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.custom-header.settings.image_label",
      "info": "t:sections.custom-header.settings.image_info"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:sections.custom-header.settings.heading",
      "info":"t:sections.custom-header.settings.heading_info"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.custom-header.settings.description"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.custom-header.settings.button_text"
    },
    {
      "type": "url",
      "id": "navigation_url",
      "label": "t:sections.custom-header.settings.navigation_url"
    },
    {
      "type": "header",
      "content": "t:sections.custom-header.settings.padding_customization"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20,
      "label": "t:sections.custom-header.settings.padding_top_desktop"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20,
      "label": "t:sections.custom-header.settings.padding_bottom_desktop"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10,
      "label": "t:sections.custom-header.settings.padding_top_mobile"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10,
      "label": "t:sections.custom-header.settings.padding_bottom_mobile"
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-header.presets.name"
    }
  ]
}
{% endschema %}